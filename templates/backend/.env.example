# Local-first defaults
APP_NAME="AI SaaS Backend"
APP_ENV=local
APP_URL=http://localhost:8000
SECRET_KEY=dev-secret-key

# AI provider: local or anthropic
AI_PROVIDER=local
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
MAX_TOKENS=2000
TEMPERATURE=0.2

# Database provider: local or supabase
DATABASE_PROVIDER=local
LOCAL_DATA_PATH=./data/local_store.json
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional Stripe settings (disabled by default)
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Default prompt family for new apps
DEFAULT_APP_TYPE=resume_builder
